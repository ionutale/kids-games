{
	"name": "kids-games",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"lint": "svelte-check --tsconfig ./jsconfig.json",
		"test": "vitest run tests/unit tests/behavioral",
		"test:e2e": "playwright test",
		"test:e2e:headed": "HEADED=true playwright test",
		"test:all": "vitest run tests/unit tests/behavioral && playwright test",
		"prepare": "svelte-kit sync || echo ''"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.7.1",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9"
	}
}
